#!/usr/bin/env bash
# jarvis — branded command shim that forwards to the real `hermes` binary.
#
# Installed on PATH by install-jarvis.sh so that every `jarvis <verb>` the
# rebranded UI tells customers to run is a real, working command. It does NOT
# reimplement anything — it locates `hermes` and exec()s it verbatim.
#
# It also guarantees a UTF-8 console so the JARVIS banner/box-art renders
# correctly, even on a legacy Windows code page (cp1252) — the same handling
# baked into bin/jarvis-banner, so branding is never mojibake in production.
set -euo pipefail

# Force UTF-8 for the child process and, on Windows, for the console itself.
export PYTHONUTF8=1
export PYTHONIOENCODING=utf-8
case "${OS:-}${OSTYPE:-}" in
  *Windows_NT*|*msys*|*cygwin*|*win32*)
    # 65001 = CP_UTF8. Best-effort; never fail the launch if it's unavailable.
    chcp.com 65001 >/dev/null 2>&1 || true
    ;;
esac

# `jarvis update` → the overlay-aware updater (finding #9): a bare
# `hermes update` pulls upstream over the branded tree and leaves the install
# unbranded until the next apply. update-jarvis.sh does the conflict-free
# revert → update → re-apply cycle instead. Falls through to plain hermes when
# no overlay checkout is found. update-jarvis.sh sets JARVIS_NO_UPDATE_WRAP=1
# on its own hermes call so this can never recurse.
if [ "${1:-}" = "update" ] && [ -z "${JARVIS_NO_UPDATE_WRAP:-}" ]; then
  for _ov in "${JARVIS_OVERLAY_DIR:-}" \
             "${LOCALAPPDATA:-$HOME/AppData/Local}/hermes/jarvis-agent" \
             "$HOME/.hermes/jarvis-agent" \
             "$HOME/jarvis/jarvis-agent"; do
    [ -n "$_ov" ] && [ -f "$_ov/update-jarvis.sh" ] || continue
    # Both install layouts keep hermes-agent next to jarvis-agent.
    _src="$(dirname "$_ov")/hermes-agent"
    [ -d "$_src" ] && export HERMES_SRC="${HERMES_SRC:-$_src}"
    shift
    exec bash "$_ov/update-jarvis.sh" "" "$@"
  done
fi

# Locate the real hermes binary (skip ourselves if a `jarvis`->`hermes`
# name collision ever occurs on PATH). Sibling candidates first: this shim is
# also installed NEXT TO hermes(.exe) in venv/Scripts and must work when run
# by absolute path from a shell whose PATH lacks that dir (e2e-caught defect).
find_hermes() {
  local c here
  here="$(cd "$(dirname "${BASH_SOURCE[0]}")" 2>/dev/null && pwd || true)"
  for c in "${here:+$here/hermes.exe}" "${here:+$here/hermes}"; do
    [ -n "$c" ] && [ -f "$c" ] && [ "$c" != "${BASH_SOURCE[0]}" ] && { echo "$c"; return 0; }
  done
  c="$(command -v hermes 2>/dev/null || true)"
  [ -n "$c" ] && { echo "$c"; return 0; }
  for c in \
    "${HERMES_BIN:-}" \
    "$HOME/.local/bin/hermes" \
    "$HOME/bin/hermes" \
    "/usr/local/bin/hermes"; do
    [ -n "$c" ] && [ -x "$c" ] && { echo "$c"; return 0; }
  done
  return 1
}

HERMES="$(find_hermes || true)"
if [ -z "$HERMES" ]; then
  echo "jarvis: could not find the 'hermes' runtime on PATH." >&2
  echo "        Reinstall with install-jarvis.sh, or add hermes to PATH." >&2
  exit 127
fi

exec "$HERMES" "$@"
